{
  "name": "@mp-labs/agentmeets-session",
  "version": "0.1.0",
  "description": "Zero-setup same-session helpers for AgentMeets invite flows",
  "type": "module",
  "main": "dist/client.js",
  "types": "dist/client.d.ts",
  "bin": {
    "agentmeets-session": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "import": "./dist/protocol.js"
    },
    "./state-store": {
      "types": "./dist/state-store.d.ts",
      "import": "./dist/state-store.js"
    },
    "./countdown": {
      "types": "./dist/countdown.d.ts",
      "import": "./dist/countdown.js"
    },
    "./draft-controller": {
      "types": "./dist/draft-controller.d.ts",
      "import": "./dist/draft-controller.js"
    },
    "./tty/raw-mode": {
      "types": "./dist/tty/raw-mode.d.ts",
      "import": "./dist/tty/raw-mode.js"
    },
    "./adapters/types": {
      "types": "./dist/adapters/types.d.ts",
      "import": "./dist/adapters/types.js"
    },
    "./adapters/detect-invite": {
      "types": "./dist/adapters/detect-invite.d.ts",
      "import": "./dist/adapters/detect-invite.js"
    },
    "./adapters/fake-session": {
      "types": "./dist/adapters/fake-session.d.ts",
      "import": "./dist/adapters/fake-session.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "bun-types": "latest",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
